# =====================================================================
# Zintta — variables de entorno (Vite)
# Copia este archivo a `.env` y reemplaza los valores.
#   cp .env.example .env
#
# Solo las variables con prefijo `VITE_` se exponen al frontend.
# =====================================================================

# ----- Supabase -----------------------------------------------------
# URL pública del proyecto (Project Settings → API → Project URL).
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Clave anónima pública (Project Settings → API → anon / public key).
# NUNCA pongas aquí la service_role key.
VITE_SUPABASE_ANON_KEY=your-anon-key

# ----- WhatsApp -----------------------------------------------------
# Número internacional sin signos ni espacios (código de país incluido).
# Ej. Colombia: 573001234567
VITE_WHATSAPP_NUMBER=573001234567
